# Array Beginning
Lnames = [
    "Pele", "Cruyff", "Maradona", "Messi", "Ronaldo",
    "Ronaldinho", "Zidane", "Buffon", "Baggio", "Maldini"
]

def display_names(names):
    for name in names:
        print(name)

def display_names_reverse(names):
    for name in reversed(names):
        print(name)

#Output
print("Names in Original Order:")
display_names(Lnames)

print("\nNames in Reverse Order:")
display_names_reverse(Lnames)
